# ---------------------------------------------------------------------------
# TPO configuration. Copy to `.env` and adjust. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Local data warehouse (DuckDB mirror) ---
TPO_DUCKDB_PATH=data/tpo.duckdb
TPO_EMBEDDINGS_PATH=data/embeddings.parquet
TPO_LGBM_MODEL_PATH=data/lgbm_lift.txt

# --- Graph store backend: "duckdb" (no Docker) or "neo4j" ---
TPO_GRAPH_BACKEND=duckdb

# --- Neo4j (Community, via docker-compose; used when TPO_GRAPH_BACKEND=neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tpo_password

# --- LLM via Ollama (OpenAI-compatible endpoint) ---
# `ollama serve` exposes this automatically. No API key needed; use a dummy.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
TPO_LLM_MODEL=qwen2.5:3b

# --- Genie backend selection: `mock` (local DuckDB) or `databricks` (real) ---
TPO_GENIE_BACKEND=mock

# --- Databricks Free Edition (only needed when TPO_GENIE_BACKEND=databricks) ---
# Workspace host, e.g. https://dbc-xxxx.cloud.databricks.com  (no trailing slash)
DATABRICKS_HOST=
# Personal access token: Settings -> Developer -> Access tokens
DATABRICKS_TOKEN=
# SQL warehouse id (SQL Warehouses -> your warehouse -> details)
DATABRICKS_WAREHOUSE_ID=
# Unity Catalog location for the ETL pull
DATABRICKS_CATALOG=tpo
DATABRICKS_SCHEMA=dunnhumby
# Genie space ids (create 2-3 spaces; map roles here)
GENIE_SPACE_SALES=
GENIE_SPACE_PROMO=
GENIE_SPACE_INVENTORY=
